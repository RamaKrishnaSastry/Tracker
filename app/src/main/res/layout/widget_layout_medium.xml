<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="horizontal"
    android:padding="14dp">

    <!-- Left side: Status and Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.2"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/widget_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Morning"
            android:textColor="#D0BCFF"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:alpha="0.8" />

        <TextView
            android:id="@+id/widget_count_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="24"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/widget_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp"
            android:progress="24"
            android:progressDrawable="@android:drawable/progress_horizontal"
            android:progressTint="#D0BCFF"
            android:progressBackgroundTint="#3A3C4A" />

        <TextView
            android:id="@+id/widget_sub_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="84 more to 108"
            android:textColor="#888888"
            android:textSize="10sp" />
        
        <TextView
            android:id="@+id/widget_lbl_lifetime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LT: 12450"
            android:textColor="#555555"
            android:textSize="9sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Right side: Content Area with ViewFlipper -->
    <ViewFlipper
        android:id="@+id/widget_flipper"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.4">

        <!-- Page 0: Quick Add Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <Button
                    android:id="@+id/btn_quick_10"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginRight="4dp"
                    android:text="+10"
                    android:textSize="10sp"
                    android:background="@drawable/widget_button_bg"
                    android:textColor="#E0E0E0"
                    android:padding="0dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp" />

                <Button
                    android:id="@+id/btn_quick_24"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginRight="4dp"
                    android:text="+24"
                    android:textSize="10sp"
                    android:background="@drawable/widget_button_bg"
                    android:textColor="#E0E0E0"
                    android:padding="0dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp" />

                <Button
                    android:id="@+id/btn_quick_28"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="+28"
                    android:textSize="10sp"
                    android:background="@drawable/widget_button_bg"
                    android:textColor="#E0E0E0"
                    android:padding="0dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp" />
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_quick_54"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginRight="4dp"
                    android:text="+54"
                    android:textSize="10sp"
                    android:background="@drawable/widget_button_bg"
                    android:textColor="#E0E0E0"
                    android:padding="0dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp" />

                <Button
                    android:id="@+id/btn_quick_108"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginRight="4dp"
                    android:text="+108"
                    android:textSize="10sp"
                    android:background="@drawable/widget_button_accent_bg"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:padding="0dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp" />

                <ImageButton
                    android:id="@+id/btn_open_app_medium"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:src="@drawable/ic_edit_white"
                    android:background="@drawable/widget_button_bg"
                    android:padding="8dp"
                    android:scaleType="fitCenter" />
            </LinearLayout>
        </LinearLayout>

        <!-- Page 1: Digit Pad (Compact) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="2dp">
                
                <TextView
                    android:id="@+id/widget_input_display"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_widget_pass_medium"
                    android:layout_width="38dp"
                    android:layout_height="18dp"
                    android:text="PASS"
                    android:textSize="7sp"
                    android:background="@drawable/widget_button_bg"
                    android:textColor="#FFA726"
                    android:layout_marginRight="4dp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btn_widget_clear_medium"
                    android:layout_width="38dp"
                    android:layout_height="18dp"
                    android:text="RESET"
                    android:textSize="7sp"
                    android:background="@drawable/widget_button_bg"
                    android:textColor="#E57373"
                    android:layout_marginRight="4dp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btn_input_back_medium"
                    android:layout_width="30dp"
                    android:layout_height="18dp"
                    android:text="ESC"
                    android:textSize="7sp"
                    android:background="@null"
                    android:textColor="#888888"
                    android:padding="0dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:layout_marginBottom="2dp">
                <Button android:id="@+id/btn_digit_1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="1" android:background="@drawable/widget_button_bg" android:textColor="#E0E0E0" android:textSize="9sp" android:layout_marginRight="2dp" />
                <Button android:id="@+id/btn_digit_2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="2" android:background="@drawable/widget_button_bg" android:textColor="#E0E0E0" android:textSize="9sp" android:layout_marginRight="2dp" />
                <Button android:id="@+id/btn_digit_3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="3" android:background="@drawable/widget_button_bg" android:textColor="#E0E0E0" android:textSize="9sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:layout_marginBottom="2dp">
                <Button android:id="@+id/btn_digit_4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="4" android:background="@drawable/widget_button_bg" android:textColor="#E0E0E0" android:textSize="9sp" android:layout_marginRight="2dp" />
                <Button android:id="@+id/btn_digit_5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="5" android:background="@drawable/widget_button_bg" android:textColor="#E0E0E0" android:textSize="9sp" android:layout_marginRight="2dp" />
                <Button android:id="@+id/btn_digit_6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="6" android:background="@drawable/widget_button_bg" android:textColor="#E0E0E0" android:textSize="9sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:layout_marginBottom="2dp">
                <Button android:id="@+id/btn_digit_7" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="7" android:background="@drawable/widget_button_bg" android:textColor="#E0E0E0" android:textSize="9sp" android:layout_marginRight="2dp" />
                <Button android:id="@+id/btn_digit_8" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="8" android:background="@drawable/widget_button_bg" android:textColor="#E0E0E0" android:textSize="9sp" android:layout_marginRight="2dp" />
                <Button android:id="@+id/btn_digit_9" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="9" android:background="@drawable/widget_button_bg" android:textColor="#E0E0E0" android:textSize="9sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
                <Button android:id="@+id/btn_digit_clear" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="C" android:background="@drawable/widget_button_bg" android:textColor="#E57373" android:textSize="9sp" android:layout_marginRight="2dp" />
                <Button android:id="@+id/btn_digit_0" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="0" android:background="@drawable/widget_button_bg" android:textColor="#E0E0E0" android:textSize="9sp" android:layout_marginRight="2dp" />
                <Button android:id="@+id/btn_digit_add" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="ADD" android:background="@drawable/widget_button_accent_bg" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="9sp" />
            </LinearLayout>
        </LinearLayout>
    </ViewFlipper>

</LinearLayout>
