<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header line -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GAYATRI JAPA TRACKER"
            android:textColor="#E57373"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_alignParentLeft="true" />
        <TextView
            android:id="@+id/widget_lbl_lifetime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LIFETIME: 0"
            android:textColor="#888888"
            android:textSize="9sp"
            android:layout_alignParentRight="true" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2C2D35"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="12dp" />

    <!-- Main counter presentation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pratah Sandhya"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_sub_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Target Sandhya is incomplete."
                android:textColor="#888888"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:orientation="vertical"
            android:gravity="right">

            <TextView
                android:id="@+id/widget_count_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="24"
                android:textColor="#E57373"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COUNT"
                android:textColor="#888888"
                android:textSize="8sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Action panel: Grid of 5 Quick Adds -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QUICK RECORD"
        android:textColor="#555555"
        android:textSize="9sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/btn_quick_10"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginRight="6dp"
            android:text="+10"
            android:textSize="11sp"
            android:background="#33D32F2F"
            android:textColor="#FFCDD2"
            android:padding="0dp"
            android:minHeight="0dp"
            android:minWidth="0dp" />

        <Button
            android:id="@+id/btn_quick_24"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginRight="6dp"
            android:text="+24"
            android:textSize="11sp"
            android:background="#33D32F2F"
            android:textColor="#FFCDD2"
            android:padding="0dp"
            android:minHeight="0dp"
            android:minWidth="0dp" />

        <Button
            android:id="@+id/btn_quick_28"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="+28"
            android:textSize="11sp"
            android:background="#33D32F2F"
            android:textColor="#FFCDD2"
            android:padding="0dp"
            android:minHeight="0dp"
            android:minWidth="0dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btn_quick_54"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginRight="6dp"
            android:text="+54"
            android:textSize="11sp"
            android:background="#33D32F2F"
            android:textColor="#FFCDD2"
            android:padding="0dp"
            android:minHeight="0dp"
            android:minWidth="0dp" />

        <Button
            android:id="@+id/btn_quick_108"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginRight="6dp"
            android:text="+108"
            android:textSize="11sp"
            android:background="#D32F2F"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:minHeight="0dp"
            android:minWidth="0dp" />

        <Button
            android:id="@+id/btn_open_app"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="OPEN"
            android:textSize="11sp"
            android:background="#44777777"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:minHeight="0dp"
            android:minWidth="0dp" />
    </LinearLayout>

    <!-- Collapsible Punascharana / All Complete helper -->
    <LinearLayout
        android:id="@+id/widget_layout_extra_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <Button
            android:id="@+id/btn_punas_108"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="+108 Punascharana Japa"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="#1E88E5"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
